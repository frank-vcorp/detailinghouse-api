# ============================================================
# DetailingHouse API — Variables de entorno
# Copia este archivo a .env para desarrollo local
# En Railway se configuran en Settings > Variables
# ============================================================

# PostgreSQL — Railway lo genera automáticamente
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — Cambia esto por una cadena segura aleatoria (mínimo 32 chars)
JWT_SECRET=cambia_esto_por_algo_muy_seguro_32chars_minimo

# Entorno
NODE_ENV=production

# Auto-migrar al arrancar (true en producción inicial, luego false)
AUTO_MIGRATE=true

# Puerto (Railway lo asigna automáticamente)
PORT=3000
